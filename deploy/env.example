# /etc/shellboto/env  (mode 0600, root:root)

# Bot token from @BotFather.
SHELLBOTO_TOKEN=123456:REPLACE_ME_WITH_YOUR_BOT_TOKEN

# Single superadmin Telegram user ID. Seeded into the users table on every
# startup (any other row marked superadmin is demoted to admin). Change it
# by editing this file and restarting the service.
SHELLBOTO_SUPERADMIN_ID=111111111

# Audit hash-chain genesis seed. 32 bytes, hex-encoded. Generate with:
#   openssl rand -hex 32
# Empty = all-zeros fallback with a startup warning. Setting this seed
# means an attacker who tampers with the DB can't silently re-chain
# without also knowing this value.
SHELLBOTO_AUDIT_SEED=
